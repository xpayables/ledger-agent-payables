# Arc testnet rail. Use throwaway wallets only.
ARC_BUYER_PRIVATE_KEY=

# Optional: stable owner key for local EIP-191 signing fallback.
# A real Ledger device can be used from the browser console instead.
OWNER_PRIVATE_KEY=

# Optional: override the Arc seller receiving address for demo payments.
ARC_PAY_TO=
ARC_SELLER_PRIVATE_KEY=
ARC_SELLER_PORT=4031
ARC_MARKET_SELLER_PORT=4032
