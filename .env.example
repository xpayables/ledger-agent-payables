# Demo buyer wallet keys. Use throwaway wallets only.
# Run `npm run wallet:buyer` to create X402_BUYER_PRIVATE_KEY in .env.
X402_BUYER_PRIVATE_KEY=

# Optional: use a separate Arc buyer key instead of X402_BUYER_PRIVATE_KEY.
X402_ARC_BUYER_PRIVATE_KEY=

# Optional: stable owner key for local EIP-191 signing fallback.
# A real Ledger device can be used from the browser console instead.
OWNER_PRIVATE_KEY=

# Optional: override the Arc seller receiving address for demo payments.
ARC_PAY_TO=
ARC_SELLER_PRIVATE_KEY=
